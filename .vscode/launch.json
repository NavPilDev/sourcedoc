{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run SourceDoc (Cursor Dev Host)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/sourcedoc"
      ],
      "outFiles": [
        "${workspaceFolder}/sourcedoc/dist/**/*.js"
      ]
    }
  ]
}